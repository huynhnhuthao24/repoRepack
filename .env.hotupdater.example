# hot-updater CLI (deploy). Copy: cp .env.hotupdater.example .env.hotupdater
#
# Key: thường dùng "anon" "public". Nếu deploy bị RLS trên Storage/bundles, chạy SQL trong
# supabase/fix-hot-updater-rls.sql HOAC chỉ trên máy deploy tạm thay bằng "service_role" secret
# (Dashboard → API → service_role) — không commit, không đưa vào app.
#
# HOT_UPDATER_SUPABASE_URL có thể bỏ trống — hot-updater.config.ts đã default project URL.
HOT_UPDATER_SUPABASE_ANON_KEY=
HOT_UPDATER_SUPABASE_BUCKET_NAME=
